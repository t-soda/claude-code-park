{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Code Park",
  "version": "0.8.0",
  "identifier": "dev.claudecodepark.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Code Park",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 20, "y": 25 }
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; worker-src 'self' blob:; connect-src 'self' ipc: http://ipc.localhost ws://localhost:1420 http://localhost:1420 blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM4RjVEMzYwNjUxRTc5QjQKUldTMGVSNWxZTlAxeU1iQVNEQnphZDYxUDFFYXRxeVJzN3JLQWNPTWdvOVY0ZlFyQnFuUEk3RHYK",
      "endpoints": [
        "https://github.com/t-soda/claude-code-park/releases/latest/download/latest.json"
      ]
    }
  }
}
